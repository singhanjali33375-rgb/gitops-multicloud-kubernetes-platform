apiVersion: v1

kind: Service


metadata:

  name: {{ include "gitops-app.fullname" . }}

  labels:

    {{- include "gitops-app.labels" . | nindent 4 }}



spec:

  type: {{ .Values.service.type }}


  selector:

    {{- include "gitops-app.selectorLabels" . | nindent 4 }}



  ports:

    - name: http

      port: {{ .Values.service.port }}


      targetPort: {{ .Values.service.targetPort }}


      protocol: TCP
